# Postfarm is bring-your-own-keys. The recommended setup is the in-app
# Settings screen; keys are saved in your local Postfarm user data folder.
#
# These variables are optional overrides for self-hosting, tests, or headless use.

# Port the local Postfarm server listens on (default 8787).
# PORT=8787

# Interface to bind (default 127.0.0.1, loopback only). The server returns
# your API keys to the Settings UI, so do not expose it to a public network
# unless you understand the risks and have your own protection in front of it.
# HOST=127.0.0.1

# Override the local data directory. By default Postfarm uses:
# - macOS: ~/Library/Application Support/Postfarm
# - Windows: %APPDATA%/Postfarm
# - Linux: ~/.config/postfarm
# POSTFARM_DIR=/path/to/postfarm-data

# Optional binary/font overrides for video rendering.
# FFMPEG_PATH=/path/to/ffmpeg
# FFPROBE_PATH=/path/to/ffprobe
# POSTFARM_FONT=/path/to/bold-font.ttf

# You do not need to put API keys here; enter them in Settings instead.
# OPENROUTER_API_KEY=your_openrouter_key_here
# DEEPSEEK_API_KEY=your_deepseek_key_here
# APIFY_API_KEY=your_apify_key_here
# POSTBRIDGE_API_KEY=your_postbridge_key_here
